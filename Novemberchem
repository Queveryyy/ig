let deck = [...ALL_CARDS];
let idx = 0;
let flipped = false;
let cardEl = null;

function buildCard(data) {
  const w = document.createElement('div');
  w.className = 'card-wrap';
  // Convert \n to <br> in question text
  const qHtml = data.q.replace(/\n/g, '<br>');
  w.innerHTML = `
    <div class="card-inner">
      <div class="card-face card-front">
        <div class="lbl lbl-right">KNOW IT ✓</div>
        <div class="lbl lbl-left">SKIP ✗</div>
        <span class="card-tag ${data.tag}">${data.label}</span>
        <p class="q-text">${qHtml}</p>
        <div class="flip-hint">tap to flip · swipe left/right to navigate</div>
      </div>
      <div class="card-face card-back">
        <div class="answer-label">Answer</div>
        <div class="a-text">${data.a}</div>
        <span class="marks">${data.marks}</span>
      </div>
    </div>`;
  return w;
}

function showCard(i) {
  const stage = document.getElementById('stage');
  if (cardEl) { cardEl.remove(); cardEl = null; }
  flipped = false;

  if (!deck.length || i >= deck.length) {
    document.getElementById('emptyState').classList.add('show');
    updateProgress(deck.length, deck.length);
    return;
  }
  document.getElementById('emptyState').classList.remove('show');
  idx = Math.max(0, Math.min(i, deck.length - 1));
  cardEl = buildCard(deck[idx]);
  stage.appendChild(cardEl);
  attachSwipe(cardEl);
  updateProgress(idx + 1, deck.length);
}

function updateProgress(cur, total) {
  const pct = total ? ((cur - 1) / total) * 100 : 100;
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressLabel').textContent = total ? `${cur} / ${total}` : 'Done!';
}

function flipCurrent() {
  if (!cardEl) return;
  flipped = !flipped;
  cardEl.classList.toggle('flipped', flipped);
}

function nextCard() { if (idx < deck.length - 1) showCard(idx + 1); }
function prevCard() { if (idx > 0) showCard(idx - 1); }
function restartDeck() { showCard(0); }

function filterCards(topic, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  deck = topic === 'all' ? [...ALL_CARDS] : ALL_CARDS.filter(c => c.topic === topic);
  showCard(0);
}

function attachSwipe(el) {
  let sx = 0, sy = 0, cx = 0, cy = 0, dragging = false;
  const SWIPE = 70, TAP_LIMIT = 10;

  function start(x, y) { sx = x; sy = y; cx = x; cy = y; dragging = false; }

  function move(x, y) {
    cx = x; cy = y;
    const dx = cx - sx;
    if (!dragging && Math.abs(dx) > TAP_LIMIT) dragging = true;
    if (!dragging) return;
    const rot = dx * 0.06;
    el.style.transform = `translateX(${dx}px) translateY(${-Math.abs(dx)*0.03}px) rotate(${rot}deg)`;
    const lblR = el.querySelector('.lbl-right');
    const lblL = el.querySelector('.lbl-left');
    if (dx > 20)       { lblR.style.opacity = Math.min((dx-20)/60,1); lblL.style.opacity = 0; }
    else if (dx < -20) { lblL.style.opacity = Math.min((-dx-20)/60,1); lblR.style.opacity = 0; }
    else               { lblR.style.opacity = 0; lblL.style.opacity = 0; }
  }

  function end() {
    const dx = cx - sx;
    const lblR = el.querySelector('.lbl-right');
    const lblL = el.querySelector('.lbl-left');
    if (lblR) lblR.style.opacity = 0;
    if (lblL) lblL.style.opacity = 0;

    if (!dragging) { el.style.transform = ''; flipCurrent(); return; }

    if (Math.abs(dx) >= SWIPE) {
      const dir = dx > 0 ? 1 : -1;
      el.style.transition = 'transform 0.28s ease, opacity 0.28s ease';
      el.style.transform = `translateX(${dir*130}%) rotate(${dir*20}deg)`;
      el.style.opacity = '0';
      setTimeout(() => dir > 0 ? nextCard() : prevCard(), 260);
    } else {
      el.style.transition = 'transform 0.38s cubic-bezier(0.34,1.56,0.64,1)';
      el.style.transform = '';
      setTimeout(() => el.style.transition = '', 400);
    }
    sx = 0; sy = 0;
  }

  el.addEventListener('touchstart', e => start(e.touches[0].clientX, e.touches[0].clientY), { passive: true });
  el.addEventListener('touchmove',  e => { move(e.touches[0].clientX, e.touches[0].clientY); if (dragging) e.preventDefault(); }, { passive: false });
  el.addEventListener('touchend',   () => end());
  el.addEventListener('mousedown',  e => { e.preventDefault(); start(e.clientX, e.clientY); });
  window.addEventListener('mousemove', e => { if (sx || sy) move(e.clientX, e.clientY); });
  window.addEventListener('mouseup',   () => { if (sx || sy) { end(); sx = 0; sy = 0; } });
}

document.addEventListener('keydown', e => {
  if      (e.key === 'ArrowRight' || e.key === 'ArrowDown')  { e.preventDefault(); nextCard(); }
  else if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')    { e.preventDefault(); prevCard(); }
  else if (e.key === ' ' || e.key === 'Enter')                { e.preventDefault(); flipCurrent(); }
});

showCard(0);
</script>

