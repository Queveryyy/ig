<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>IGCSE Chemistry Nov 2025</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f14;
    --surface: #161a24;
    --card-front: #1c2135;
    --card-back: #101828;
    --accent: #00d4ff;
    --accent2: #7c3aed;
    --text: #f0f2f8;
    --text-muted: #8890a4;
    --border: rgba(0,212,255,0.18);
    --green: #00e5a0;
  }

- { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘DM Sans’, sans-serif;
min-height: 100vh;
display: flex;
flex-direction: column;
align-items: center;
}

/* ── Header ── */
header {
width: 100%;
background: var(–bg);
border-bottom: 1px solid var(–border);
padding: 16px 20px 12px;
text-align: center;
position: sticky;
top: 0;
z-index: 50;
}
header h1 {
font-family: ‘Space Mono’, monospace;
font-size: 1rem;
color: var(–accent);
letter-spacing: 0.06em;
}
header p {
color: var(–text-muted);
font-size: 0.72rem;
margin-top: 3px;
font-family: ‘Space Mono’, monospace;
}
.progress-wrap {
display: flex;
align-items: center;
gap: 10px;
margin: 10px auto 0;
max-width: 420px;
}
.progress-bar { flex: 1; height: 4px; background: rgba(255,255,255,0.08); border-radius: 4px; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, var(–accent), var(–accent2)); border-radius: 4px; transition: width 0.4s; width: 0%; }
.progress-label { font-family: ‘Space Mono’, monospace; font-size: 0.7rem; color: var(–text-muted); white-space: nowrap; }

/* ── Filter ── */
.filter-bar {
width: 100%;
display: flex;
gap: 8px;
padding: 10px 14px;
overflow-x: auto;
scrollbar-width: none;
border-bottom: 1px solid rgba(255,255,255,0.05);
position: sticky;
top: 82px;
background: var(–bg);
z-index: 40;
}
.filter-bar::-webkit-scrollbar { display: none; }
.filter-btn {
flex-shrink: 0;
background: var(–surface);
border: 1px solid var(–border);
color: var(–text-muted);
font-family: ‘Space Mono’, monospace;
font-size: 0.65rem;
padding: 6px 14px;
border-radius: 20px;
cursor: pointer;
white-space: nowrap;
transition: all 0.2s;
}
.filter-btn.active { background: var(–accent); color: #000; border-color: var(–accent); font-weight: 700; }

/* ── Stage ── */
.stage {
width: 100%;
max-width: 560px;
padding: 30px 20px 10px;
display: flex;
flex-direction: column;
align-items: center;
position: relative;
min-height: 420px;
}

/* Ghost stack */
.ghost {
position: absolute;
width: calc(100% - 40px);
max-width: 520px;
height: 320px;
border-radius: 20px;
background: var(–card-front);
border: 1px solid var(–border);
pointer-events: none;
}
.ghost-2 { top: 38px; transform: scale(0.92); opacity: 0.25; z-index: 0; }
.ghost-1 { top: 22px; transform: scale(0.96); opacity: 0.5;  z-index: 1; }

/* ── Card ── */
.card-wrap {
width: 100%;
max-width: 520px;
height: 320px;
perspective: 1200px;
position: relative;
z-index: 2;
cursor: grab;
user-select: none;
touch-action: none;
}
.card-wrap:active { cursor: grabbing; }

.card-inner {
width: 100%; height: 100%;
position: relative;
transform-style: preserve-3d;
transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);
border-radius: 20px;
}
.card-wrap.flipped .card-inner { transform: rotateY(180deg); }

.card-face {
position: absolute;
inset: 0;
border-radius: 20px;
padding: 24px 26px;
backface-visibility: hidden;
-webkit-backface-visibility: hidden;
display: flex;
flex-direction: column;
overflow: hidden;
}

.card-front {
background: var(–card-front);
border: 1px solid var(–border);
justify-content: space-between;
}
.card-back {
background: var(–card-back);
border: 1px solid rgba(124,58,237,0.4);
transform: rotateY(180deg);
}

/* Swipe labels */
.lbl {
position: absolute;
top: 20px;
font-family: ‘Space Mono’, monospace;
font-size: 0.9rem;
font-weight: 700;
padding: 5px 12px;
border-radius: 7px;
border: 2.5px solid;
opacity: 0;
pointer-events: none;
z-index: 10;
backface-visibility: hidden;
-webkit-backface-visibility: hidden;
}
.lbl-right { left: 20px;  color: var(–green); border-color: var(–green); transform: rotate(-12deg); }
.lbl-left  { right: 20px; color: #ff5078;       border-color: #ff5078;      transform: rotate(12deg); }

/* Card tag */
.card-tag {
font-family: ‘Space Mono’, monospace;
font-size: 0.62rem;
letter-spacing: 0.1em;
text-transform: uppercase;
padding: 4px 10px;
border-radius: 10px;
display: inline-block;
margin-bottom: 12px;
align-self: flex-start;
flex-shrink: 0;
}
.tag-q1  { background: rgba(0,229,160,0.1);  color: var(–green);  border: 1px solid rgba(0,229,160,0.25); }
.tag-q2  { background: rgba(0,212,255,0.1);  color: var(–accent); border: 1px solid rgba(0,212,255,0.25); }
.tag-q3  { background: rgba(255,180,0,0.1);  color: #ffb400;       border: 1px solid rgba(255,180,0,0.25); }
.tag-q4  { background: rgba(255,80,120,0.1); color: #ff5078;       border: 1px solid rgba(255,80,120,0.25); }
.tag-q5  { background: rgba(124,58,237,0.1); color: #a78bfa;       border: 1px solid rgba(124,58,237,0.25); }
.tag-q6  { background: rgba(16,185,129,0.1); color: #34d399;       border: 1px solid rgba(16,185,129,0.25); }
.tag-q7  { background: rgba(251,146,60,0.1); color: #fb923c;       border: 1px solid rgba(251,146,60,0.25); }
.tag-q8  { background: rgba(56,189,248,0.1); color: #38bdf8;       border: 1px solid rgba(56,189,248,0.25); }
.tag-q9  { background: rgba(236,72,153,0.1); color: #f472b6;       border: 1px solid rgba(236,72,153,0.25); }
.tag-q10 { background: rgba(245,158,11,0.1); color: #fbbf24;       border: 1px solid rgba(245,158,11,0.25); }

/* Question text */
.q-text {
font-size: 1.05rem;
line-height: 1.6;
color: var(–text);
flex: 1;
overflow-y: auto;
font-weight: 500;
}
.flip-hint {
font-family: ‘Space Mono’, monospace;
font-size: 0.62rem;
color: var(–text-muted);
display: flex;
align-items: center;
gap: 5px;
margin-top: 10px;
flex-shrink: 0;
}
.flip-hint::before { content: ‘↻’; font-size: 0.8rem; }

/* Answer */
.answer-label {
font-family: ‘Space Mono’, monospace;
font-size: 0.62rem;
letter-spacing: 0.1em;
color: #a78bfa;
text-transform: uppercase;
margin-bottom: 10px;
display: flex;
align-items: center;
gap: 6px;
flex-shrink: 0;
}
.answer-label::before { content: ‘✓’; color: var(–green); }

.a-text {
font-size: 1rem;
line-height: 1.65;
color: #d0d8ee;
overflow-y: auto;
flex: 1;
font-weight: 400;
}
.a-text::-webkit-scrollbar { width: 3px; }
.a-text::-webkit-scrollbar-thumb { background: var(–accent2); border-radius: 3px; }

.marks {
font-family: ‘Space Mono’, monospace;
font-size: 0.62rem;
color: var(–text-muted);
align-self: flex-end;
margin-top: 8px;
flex-shrink: 0;
}

code {
font-family: ‘Space Mono’, monospace;
background: rgba(0,212,255,0.1);
padding: 2px 6px;
border-radius: 4px;
font-size: 0.9em;
color: var(–accent);
}

/* ── Bottom controls ── */
.bottom-bar {
width: 100%;
display: flex;
align-items: center;
justify-content: center;
gap: 12px;
padding: 16px 20px 28px;
background: var(–bg);
border-top: 1px solid rgba(255,255,255,0.05);
position: sticky;
bottom: 0;
}
.ctrl-btn {
font-family: ‘Space Mono’, monospace;
font-size: 0.72rem;
padding: 10px 20px;
border-radius: 10px;
border: none;
cursor: pointer;
transition: all 0.2s;
letter-spacing: 0.03em;
}
.ctrl-prev, .ctrl-next { background: var(–surface); color: var(–text-muted); border: 1px solid var(–border); }
.ctrl-prev:hover, .ctrl-next:hover { border-color: var(–accent); color: var(–accent); }
.ctrl-flip { background: var(–accent2); color: #fff; font-weight: 700; font-size: 0.8rem; padding: 12px 28px; }
.ctrl-flip:hover { background: #6d28d9; }

/* ── Empty ── */
.empty-state {
display: none;
flex-direction: column;
align-items: center;
gap: 14px;
padding: 60px 20px;
text-align: center;
width: 100%;
}
.empty-state.show { display: flex; }
.empty-state p { font-family: ‘Space Mono’, monospace; font-size: 0.85rem; color: var(–text-muted); }
.restart-btn {
font-family: ‘Space Mono’, monospace;
font-size: 0.75rem;
padding: 12px 24px;
border-radius: 10px;
background: var(–accent);
color: #000;
font-weight: 700;
border: none;
cursor: pointer;
}
</style>

</head>
<body>

<header>
  <h1>IGCSE CHEMISTRY — NOV 2025</h1>
  <p>swipe left / right to navigate · tap to flip</p>
  <div class="progress-wrap">
    <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
    <span class="progress-label" id="progressLabel">1 / 28</span>
  </div>
</header>

<div class="filter-bar">
  <button class="filter-btn active" onclick="filterCards('all',this)">All</button>
  <button class="filter-btn" onclick="filterCards('q1',this)">Q1 · Ions</button>
  <button class="filter-btn" onclick="filterCards('q2',this)">Q2 · Na</button>
  <button class="filter-btn" onclick="filterCards('q3',this)">Q3 · Halogens</button>
  <button class="filter-btn" onclick="filterCards('q4',this)">Q4 · Electrolysis</button>
  <button class="filter-btn" onclick="filterCards('q5',this)">Q5 · Rates</button>
  <button class="filter-btn" onclick="filterCards('q6',this)">Q6 · PVC</button>
  <button class="filter-btn" onclick="filterCards('q7',this)">Q7 · Ethanol</button>
  <button class="filter-btn" onclick="filterCards('q8',this)">Q8 · Air</button>
  <button class="filter-btn" onclick="filterCards('q9',this)">Q9 · CuSO₄</button>
  <button class="filter-btn" onclick="filterCards('q10',this)">Q10 · NH₃</button>
</div>

<div class="stage" id="stage">
  <div class="ghost ghost-2"></div>
  <div class="ghost ghost-1"></div>
  <div class="empty-state" id="emptyState">
    <p>🎉 All cards done!</p>
    <button class="restart-btn" onclick="restartDeck()">Start Again</button>
  </div>
</div>

<div class="bottom-bar">
  <button class="ctrl-btn ctrl-prev" onclick="prevCard()">← Prev</button>
  <button class="ctrl-btn ctrl-flip" onclick="flipCurrent()">Flip Card</button>
  <button class="ctrl-btn ctrl-next" onclick="nextCard()">Next →</button>
</div>

